# copane Environment Configuration
# Copy this file to ~/.copane.env and add your API keys

# DeepSeek API (recommended)
# Get your API key from: https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# OpenAI API (optional)
# Get your API key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# LangSmith (optional - for tracing)
# LANGCHAIN_API_KEY=your_langsmith_api_key_here

# Model Configuration
# Default model: deepseek-chat
# Available models: deepseek-chat, gpt-4o, local-ollama

# Local Ollama Configuration (optional)
# If using local-ollama model, make sure Ollama is running:
#   ollama serve
# And pull the model:
#   ollama pull gemma4:26b

# Proxy Configuration (optional)
# HTTP_PROXY=http://proxy.example.com:8080
# HTTPS_PROXY=http://proxy.example.com:8080

# Logging Configuration (optional)
# COPANE_LOG_LEVEL=INFO  # DEBUG, INFO, WARNING, ERROR
# COPANE_LOG_FILE=~/.copane.log
